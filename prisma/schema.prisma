generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ NextAuth ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("USER")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships OrganizationMember[]
  spvToken    SpvToken?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ OrganizaГ€вЂєie (firma de administrare Гўв‚¬вЂќ tenant SaaS) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Organization {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  cui                  String?
  address              String?
  phone                String?
  email                String?
  logoUrl              String?
  plan                 String    @default("starter")
  status               String    @default("active")
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  members     OrganizationMember[]
  asociatii   Asociatie[]
  furnizori   Furnizor[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("MEMBER")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ AsociaГ€вЂєii de proprietari ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Asociatie {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  address          String?
  city             String   @default("BucureГ€в„ўti")
  sector           String?
  cui              String?
  regCom           String?
  bank             String?
  iban             String?
  ibanCasa         String?
  phone            String?
  email            String?
  adminName        String?
  presedinteName   String?
  cenzorName       String?
  nrApartamente    Int      @default(0)
  nrScari          Int      @default(1)
  anConstructie    Int?
  blocuriJson      String?  // JSON Гўв‚¬вЂќ configurare blocuri/scГ„Ж’ri
  wizardData       String?  // JSON Гўв‚¬вЂќ configurare completГ„Ж’ din wizard
  wizardStep       Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apartamente   Apartament[]
  fonduri       FondAsociatie[]
  furnizori     FurnizorAsociatie[]
  facturi       Factura[]
  incasari      Incasare[]
  incasariSerii IncasareSerie[]
  listeIntretinere ListaLuna[]
  grupuri          GrupApartamente[]
  transferuri      Transfer[]
  transferuriFonduri TransferFond[]
  spvInvoices      SpvInvoice[]
  angajati         Angajat[]
  statePlata       StatPlata[]

  @@index([organizationId])
}

model GrupApartamente {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  name           String
  apartamentIds  String   // JSON: ["id1","id2",...]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asociatie Asociatie @relation(fields: [asociatieId], references: [id], onDelete: Cascade)

  @@index([asociatieId])
  @@index([organizationId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Apartamente ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Apartament {
  id             String   @id @default(cuid())
  asociatieId    String
  organizationId String
  numar          String
  scara          String?
  etaj           Int?
  suprafata      Float?
  nrPersone      Int      @default(1)
  cotaParte      Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asociatie   Asociatie              @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  proprietari ApartamentProprietar[]
  solduri     SoldApartament[]
  fonduri     FondApartament[]
  contoare    Contor[]
  incasari    Incasare[]
  listaRanduri ListaLunaApartament[]

  @@unique([asociatieId, numar])
  @@index([asociatieId])
  @@index([organizationId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Proprietari ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Proprietar {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  nume           String
  prenume        String?
  cnp            String?
  email          String?
  telefon        String?
  adresa         String?
  tip            String   @default("proprietar") // proprietar / chirias
  emailuriJson   String?  // JSON array de email-uri
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  apartamente ApartamentProprietar[]

  @@index([asociatieId])
  @@index([organizationId])
}

model ApartamentProprietar {
  id           String   @id @default(cuid())
  apartamentId String
  proprietarId String
  isMain       Boolean  @default(true)
  createdAt    DateTime @default(now())

  apartament Apartament @relation(fields: [apartamentId], references: [id], onDelete: Cascade)
  proprietar Proprietar @relation(fields: [proprietarId], references: [id], onDelete: Cascade)

  @@unique([apartamentId, proprietarId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Solduri per apartament ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
// Un rГѓВўnd per apartament Гўв‚¬вЂќ se actualizeazГ„Ж’ la fiecare operaГ€вЂєie

model SoldApartament {
  id                  String   @id @default(cuid())
  apartamentId        String   @unique
  asociatieId         String
  restantaIntretinere Float    @default(0)
  intretinereCurenta  Float    @default(0)
  updatedAt           DateTime @updatedAt

  apartament Apartament @relation(fields: [apartamentId], references: [id], onDelete: Cascade)

  @@index([asociatieId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Fonduri ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model FondAsociatie {
  id          String   @id @default(cuid())
  asociatieId String
  name        String
  isEnabled   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  asociatie Asociatie       @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  solduri   FondApartament[]

  @@index([asociatieId])
}

model FondApartament {
  id             String   @id @default(cuid())
  apartamentId   String
  asociatieId    String
  fondId         String
  restanta       Float    @default(0)
  sold           Float    @default(0)
  updatedAt      DateTime @updatedAt

  apartament Apartament    @relation(fields: [apartamentId], references: [id], onDelete: Cascade)
  fond       FondAsociatie @relation(fields: [fondId], references: [id], onDelete: Cascade)

  @@unique([apartamentId, fondId])
  @@index([asociatieId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Furnizori ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Furnizor {
  id             String   @id @default(cuid())
  organizationId String
  nume           String
  cui            String?
  adresa         String?
  telefon        String?
  email          String?
  iban           String?
  banca          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asociatii    FurnizorAsociatie[]
  facturi      Factura[]

  @@index([organizationId])
}

model FurnizorAsociatie {
  id          String @id @default(cuid())
  furnizorId  String
  asociatieId String

  furnizor  Furnizor  @relation(fields: [furnizorId], references: [id], onDelete: Cascade)
  asociatie Asociatie @relation(fields: [asociatieId], references: [id], onDelete: Cascade)

  @@unique([furnizorId, asociatieId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Facturi ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Factura {
  id              String    @id @default(cuid())
  organizationId  String
  asociatieId     String
  furnizorId      String?
  serie           String?
  numar           String?
  valoare         Float
  tva             Float     @default(0)
  dataEmiterii    DateTime?
  dataScadenta    DateTime?
  luna            Int?
  an              Int?
  status          String    @default("neplatita") // neplatita / partial / platita
  categorie       String?   // intretinere / reparatii / utilitati / etc
  pdfPath         String?
  distribuireJson String?   // JSON array cu distribuirile pe apartamente
  aiProcessed     Boolean   @default(false)
  aiData          String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  asociatie Asociatie @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  furnizor  Furnizor? @relation(fields: [furnizorId], references: [id])
  plati     Plata[]

  @@index([asociatieId])
  @@index([organizationId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ PlГ„Ж’Г€вЂєi facturi ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Plata {
  id        String   @id @default(cuid())
  facturaId String
  suma      Float
  data      DateTime @default(now())
  metoda    String   @default("banca") // casa / banca / online
  notes     String?
  createdAt DateTime @default(now())

  factura Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@index([facturaId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ ГѓЕЅncasГ„Ж’ri proprietari ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model IncasareSerie {
  id             String   @id @default(cuid())
  asociatieId    String   @unique
  organizationId String
  serie          String   @default("CH")
  urmatorulNumar Int      @default(1)
  updatedAt      DateTime @updatedAt

  asociatie Asociatie @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
}

model Incasare {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  apartamentId   String
  nrApartament   String
  proprietarNume String?
  serie          String
  numarDocument  Int
  tipDocument    String   @default("chitanta") // chitanta / dispozitie_incasare / proces_verbal
  data           DateTime @default(now())
  tipPlata       String   @default("casa") // casa / banca / online
  sumaIncasata   Float
  totalSelectat  Float    @default(0)
  avansJson      String?  // JSON avans { suma, destinatie }
  pozitiiJson    String?  // JSON pozitii platite [{ tip, denumire, suma }]
  observatii     String?
  createdAt      DateTime @default(now())

  asociatie  Asociatie  @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  apartament Apartament @relation(fields: [apartamentId], references: [id])

  @@index([asociatieId])
  @@index([apartamentId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Transferuri ГѓВ®ntre conturi (casГ„Ж’ ГўвЂ вЂќ bancГ„Ж’) ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Transfer {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  data           DateTime @default(now())
  suma           Float
  dinCont        String   // "CasГ„Ж’" sau numele bГ„Ж’ncii
  inCont         String   // "CasГ„Ж’" sau numele bГ„Ж’ncii
  notes          String?
  createdAt      DateTime @default(now())

  asociatie Asociatie @relation(fields: [asociatieId], references: [id], onDelete: Cascade)

  @@index([asociatieId])
  @@index([organizationId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Transferuri ГѓВ®ntre fonduri ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model TransferFond {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  data           DateTime @default(now())
  suma           Float
  dinFondId      String
  dinFondName    String
  inFondId       String
  inFondName     String
  notes          String?
  createdAt      DateTime @default(now())

  asociatie Asociatie @relation(fields: [asociatieId], references: [id], onDelete: Cascade)

  @@index([asociatieId])
  @@index([organizationId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Lista de ГѓВ®ntreГ€вЂєinere lunarГ„Ж’ ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model ListaLuna {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  luna           Int
  an             Int
  status         String   @default("draft") // draft / publicata / inchisa
  coloane        String?  // JSON Гўв‚¬вЂќ definiГ€вЂєiile coloanelor de cheltuieli
  totalCheltuieli Float   @default(0)
  publicatAt     DateTime?
  inchisaAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asociatie   Asociatie             @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  apartamente ListaLunaApartament[]

  @@unique([asociatieId, luna, an])
  @@index([asociatieId])
}

model ListaLunaApartament {
  id          String @id @default(cuid())
  listaId     String
  apartamentId String
  numarAp     String
  proprietar  String?
  nrPersone   Int    @default(1)
  suprafata   Float?
  cotaParte   Float?
  valoriJson  String?  // JSON Гўв‚¬вЂќ valorile pe coloane
  totalLuna   Float  @default(0)
  restantaVeche Float @default(0)
  totalDePlata Float @default(0)
  achitat     Float  @default(0)
  rest        Float  @default(0)

  lista      ListaLuna  @relation(fields: [listaId], references: [id], onDelete: Cascade)
  apartament Apartament @relation(fields: [apartamentId], references: [id])

  @@unique([listaId, apartamentId])
  @@index([listaId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ Contoare ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Contor {
  id             String   @id @default(cuid())
  apartamentId   String
  asociatieId    String
  organizationId String
  tip            String   // apa_rece / apa_calda / electric / gaz
  locatie        String?  // bucatarie / baie / baie_mica / general / gradina / custom
  denumire       String?  // eticheta afiГ€в„ўatГ„Ж’ (mai ales pentru contoare custom)
  numarSerie     String?
  furnizor       String?  // ISTA / Techem / Cagero / manual
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  apartament Apartament    @relation(fields: [apartamentId], references: [id], onDelete: Cascade)
  citiri     CitireContor[]

  @@index([apartamentId])
}

model CitireContor {
  id            String    @id @default(cuid())
  contorId      String
  valoare       Float
  valoarePrev   Float?
  consum        Float?
  luna          Int
  an            Int
  dataCitire    DateTime?
  sursa         String    @default("manual") // manual / import / ai
  importBatchId String?
  notes         String?
  createdAt     DateTime  @default(now())

  contor Contor @relation(fields: [contorId], references: [id], onDelete: Cascade)

  @@unique([contorId, luna, an])
  @@index([contorId])
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ SPV / e-FacturГ„Ж’ ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model SpvToken {
  id           String    @id @default(cuid())
  userId       String    @unique
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SpvInvoice {
  id             String    @id
  organizationId String
  asociatieId    String
  uploadId       String?
  downloadId     String?
  supplier       String?
  supplierCui    String?
  invoiceNumber  String?
  issueDate      DateTime?
  total          Float?
  vatAmount      Float?
  currency       String    @default("RON")
  status         String    @default("NEW")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  asociatie Asociatie @relation(fields: [asociatieId], references: [id], onDelete: Cascade)

  @@index([asociatieId])
  @@index([organizationId])
}

// в”Ђв”Ђв”Ђ Salarii в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model Angajat {
  id                 String    @id @default(cuid())
  organizationId     String
  asociatieId        String
  nume               String
  prenume            String?
  cnp                String?
  functie            String?
  tipContract        String    @default("CIM")
  dataAngajare       DateTime?
  dataIncetare       DateTime?
  salariuBrut        Float     @default(0)
  deducerePersonala  Float     @default(0)
  normaDeLucru       Float     @default(8)
  contBancar         String?
  banca              String?
  email              String?
  telefon            String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  asociatie  Asociatie       @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  randuri    StatPlataRand[]

  @@index([asociatieId])
  @@index([organizationId])
}

model StatPlata {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  luna           Int
  an             Int
  status         String   @default("draft")
  totalBrut      Float    @default(0)
  totalNet       Float    @default(0)
  totalCas       Float    @default(0)
  totalCass      Float    @default(0)
  totalImpozit   Float    @default(0)
  totalCam       Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asociatie Asociatie       @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  randuri   StatPlataRand[]

  @@unique([asociatieId, luna, an])
  @@index([asociatieId])
  @@index([organizationId])
}

model StatPlataRand {
  id            String  @id @default(cuid())
  statPlataId   String
  angajatId     String
  zileLucrate   Int     @default(22)
  zileLibere    Int     @default(0)
  oreSupliment  Float   @default(0)
  salariuBrut   Float   @default(0)
  deducere      Float   @default(0)
  cas           Float   @default(0)
  cass          Float   @default(0)
  impozit       Float   @default(0)
  altRetineri   Float   @default(0)
  cam           Float   @default(0)
  salariuNet    Float   @default(0)

  statPlata StatPlata @relation(fields: [statPlataId], references: [id], onDelete: Cascade)
  angajat   Angajat   @relation(fields: [angajatId],   references: [id])

  @@unique([statPlataId, angajatId])
  @@index([statPlataId])
}
