generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ NextAuth Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

// role: SUPER_ADMIN | USER
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("USER")
  isActive      Boolean   @default(true)
  isSuspended   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  memberships  OrganizationMember[]
  asocUsers    AsociatieUser[]
  invitations  UserInvitation[]     @relation("InvitationCreator")
  spvToken     SpvToken?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ OrganizaÃˆâ€ºie (firma de administrare Ã¢â‚¬â€ tenant SaaS) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

model Organization {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  cui                  String?
  address              String?
  phone                String?
  email                String?
  logoUrl              String?
  plan                 String    @default("starter")
  status               String    @default("active")
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  members     OrganizationMember[]
  asociatii   Asociatie[]
  furnizori   Furnizor[]
  asocUsers   AsociatieUser[]
  invitations UserInvitation[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("MEMBER")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ AsociaÃˆâ€ºii de proprietari Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

model Asociatie {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  address          String?
  city             String   @default("BucureÃˆâ„¢ti")
  sector           String?
  cui              String?
  regCom           String?
  bank             String?
  iban             String?
  ibanCasa         String?
  phone            String?
  email            String?
  adminName        String?
  presedinteName   String?
  cenzorName       String?
  nrApartamente    Int      @default(0)
  nrScari          Int      @default(1)
  anConstructie    Int?
  blocuriJson      String?  // JSON Ã¢â‚¬â€ configurare blocuri/scÃ„Æ’ri
  wizardData       String?  // JSON Ã¢â‚¬â€ configurare completÃ„Æ’ din wizard
  wizardStep       Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apartamente   Apartament[]
  fonduri       FondAsociatie[]
  furnizori     FurnizorAsociatie[]
  facturi       Factura[]
  incasari      Incasare[]
  incasariSerii IncasareSerie[]
  listeIntretinere ListaLuna[]
  grupuri          GrupApartamente[]
  transferuri      Transfer[]
  transferuriFonduri TransferFond[]
  spvInvoices      SpvInvoice[]
  angajati         Angajat[]
  statePlata       StatPlata[]
  asocUsers        AsociatieUser[]
  invitations      UserInvitation[]
  avansuriFurnizori AvansFurnizor[]

  @@index([organizationId])
}

// ─── Utilizatori la nivel de asociație ────────────────────────────────────────
// role: PRESEDINTE | CENZOR | PROPRIETAR

model AsociatieUser {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  userId         String
  role           String   // PRESEDINTE | CENZOR | PROPRIETAR
  apartamentId   String?  // pentru PROPRIETAR
  permissions    String?  // JSON granular (scalabil)
  isSuspended    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asociatie    Asociatie    @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([asociatieId, userId])
  @@index([userId])
  @@index([organizationId])
  @@index([asociatieId])
}

model UserInvitation {
  id             String    @id @default(cuid())
  organizationId String
  asociatieId    String?
  email          String
  name           String?
  role           String    // PRESEDINTE | CENZOR | PROPRIETAR
  apartamentId   String?
  token          String    @unique @default(cuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdById    String
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asociatie    Asociatie?   @relation(fields: [asociatieId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("InvitationCreator", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([token])
  @@index([email])
}

model GrupApartamente {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  name           String
  apartamentIds  String   // JSON: ["id1","id2",...]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asociatie Asociatie @relation(fields: [asociatieId], references: [id], onDelete: Cascade)

  @@index([asociatieId])
  @@index([organizationId])
}

// Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ Apartamente Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

model Apartament {
  id             String   @id @default(cuid())
  asociatieId    String
  organizationId String
  numar          String
  scara          String?
  etaj           Int?
  suprafata      Float?
  nrPersone      Int      @default(1)
  cotaParte      Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asociatie   Asociatie              @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  proprietari ApartamentProprietar[]
  solduri     SoldApartament[]
  fonduri     FondApartament[]
  contoare    Contor[]
  incasari    Incasare[]
  listaRanduri ListaLunaApartament[]

  @@unique([asociatieId, numar])
  @@index([asociatieId])
  @@index([organizationId])
}

// Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ Proprietari Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

model Proprietar {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  nume           String
  prenume        String?
  cnp            String?
  email          String?
  telefon        String?
  adresa         String?
  tip            String   @default("proprietar") // proprietar / chirias
  emailuriJson   String?  // JSON array de email-uri
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  apartamente ApartamentProprietar[]

  @@index([asociatieId])
  @@index([organizationId])
}

model ApartamentProprietar {
  id           String   @id @default(cuid())
  apartamentId String
  proprietarId String
  isMain       Boolean  @default(true)
  createdAt    DateTime @default(now())

  apartament Apartament @relation(fields: [apartamentId], references: [id], onDelete: Cascade)
  proprietar Proprietar @relation(fields: [proprietarId], references: [id], onDelete: Cascade)

  @@unique([apartamentId, proprietarId])
}

// Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ Solduri per apartament Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
// Un rÃƒÂ¢nd per apartament Ã¢â‚¬â€ se actualizeazÃ„Æ’ la fiecare operaÃˆâ€ºie

model SoldApartament {
  id                  String   @id @default(cuid())
  apartamentId        String   @unique
  asociatieId         String
  restantaIntretinere Float    @default(0)
  intretinereCurenta  Float    @default(0)
  updatedAt           DateTime @updatedAt

  apartament Apartament @relation(fields: [apartamentId], references: [id], onDelete: Cascade)

  @@index([asociatieId])
}

// Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ Fonduri Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

model FondAsociatie {
  id          String   @id @default(cuid())
  asociatieId String
  name        String
  isEnabled   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  asociatie Asociatie       @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  solduri   FondApartament[]

  @@index([asociatieId])
}

model FondApartament {
  id             String   @id @default(cuid())
  apartamentId   String
  asociatieId    String
  fondId         String
  restanta       Float    @default(0)
  sold           Float    @default(0)
  updatedAt      DateTime @updatedAt

  apartament Apartament    @relation(fields: [apartamentId], references: [id], onDelete: Cascade)
  fond       FondAsociatie @relation(fields: [fondId], references: [id], onDelete: Cascade)

  @@unique([apartamentId, fondId])
  @@index([asociatieId])
}

// Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ Furnizori Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬

model Furnizor {
  id             String   @id @default(cuid())
  organizationId String
  nume           String
  cui            String?
  adresa         String?
  telefon        String?
  email          String?
  iban           String?
  banca          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asociatii    FurnizorAsociatie[]
  facturi      Factura[]
  avansuri     AvansFurnizor[]

  @@index([organizationId])
}

model FurnizorAsociatie {
  id          String @id @default(cuid())
  furnizorId  String
  asociatieId String

  furnizor  Furnizor  @relation(fields: [furnizorId], references: [id], onDelete: Cascade)
  asociatie Asociatie @relation(fields: [asociatieId], references: [id], onDelete: Cascade)

  @@unique([furnizorId, asociatieId])
}

