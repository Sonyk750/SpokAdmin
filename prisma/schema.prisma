  // Contributii asociatie
  asocSanatate         Boolean   @default(false)
  asocSomaj            Boolean   @default(false)
  asocPensie           Boolean   @default(false)
  asocConcedii         Boolean   @default(false)
  asocFondRisc         Boolean   @default(false)
  asocCAM              Boolean   @default(true)

  // Plata
  contBancar           String?
  banca                String?

  // Contact
  email                String?
  telefon              String?

  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  asociatie           Asociatie            @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  randuri             StatPlataRand[]
  persoaneIntretinere PersoanaIntretinere[]
  coasigurati         Coasigurat[]

  @@index([asociatieId])
  @@index([organizationId])
}

model PersoanaIntretinere {
  id        String  @id @default(cuid())
  angajatId String
  nume      String
  prenume   String?
  cnp       String?
  relatie   String? // sot/sotie, copil, parinte, etc.

  angajat Angajat @relation(fields: [angajatId], references: [id], onDelete: Cascade)

  @@index([angajatId])
}

model Coasigurat {
  id        String  @id @default(cuid())
  angajatId String
  nume      String
  prenume   String?
  cnp       String?
  relatie   String?

  angajat Angajat @relation(fields: [angajatId], references: [id], onDelete: Cascade)

  @@index([angajatId])
}

model StatPlata {
  id             String   @id @default(cuid())
  organizationId String
  asociatieId    String
  luna           Int
  an             Int
  status         String   @default("draft")
  totalBrut      Float    @default(0)
  totalNet       Float    @default(0)
  totalCas       Float    @default(0)
  totalCass      Float    @default(0)
  totalImpozit   Float    @default(0)
  totalCam       Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asociatie Asociatie       @relation(fields: [asociatieId], references: [id], onDelete: Cascade)
  randuri   StatPlataRand[]

  @@unique([asociatieId, luna, an])
  @@index([asociatieId])
  @@index([organizationId])
}

model StatPlataRand {
  id            String  @id @default(cuid())
  statPlataId   String
  angajatId     String
  zileLucrate   Int     @default(22)
  zileLibere    Int     @default(0)
  oreSupliment  Float   @default(0)
  salariuBrut   Float   @default(0)
  deducere      Float   @default(0)
  cas           Float   @default(0)
  cass          Float   @default(0)
  impozit       Float   @default(0)
  altRetineri   Float   @default(0)
  cam           Float   @default(0)
  salariuNet    Float   @default(0)

  statPlata StatPlata @relation(fields: [statPlataId], references: [id], onDelete: Cascade)
  angajat   Angajat   @relation(fields: [angajatId],   references: [id])

  @@unique([statPlataId, angajatId])
  @@index([statPlataId])
}
